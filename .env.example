# Swarm Gateway Configuration
# Public gateway (default) - managed by DataFund
SWARM_GATEWAY_URL=https://provenance-gateway.datafund.io

# Local gateway (for self-hosted deployments)
# SWARM_GATEWAY_URL=http://localhost:8000

# Default stamp parameters
DEFAULT_STAMP_DURATION_HOURS=25
DEFAULT_STAMP_SIZE=small

# Payment Configuration
# Gateway payment tier: "free" for rate-limited free tier (3 req/min)
PAYMENT_MODE=free

# MCP Server Configuration
MCP_SERVER_NAME=swarm-provenance-mcp
MCP_SERVER_VERSION=0.1.0

# Chain Anchoring Configuration
# Enable on-chain provenance via DataProvenance smart contract.
# Blockchain deps (web3, eth-account) are included in the default install.
# Read-only tools (verify_hash, get_provenance, chain_health, etc.) work
# without a wallet key. Write tools (anchor_hash, record_transform) require
# PROVENANCE_WALLET_KEY with a funded wallet.
CHAIN_ENABLED=false
# CHAIN_NAME=base-sepolia
# PROVENANCE_WALLET_KEY=0x...your_private_key_here...
# Default RPC is https://sepolia.base.org (public, no API key needed).
# Override only if you have a private Alchemy/Infura endpoint:
# CHAIN_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# Fallback RPCs (comma-separated, tried in order after CHAIN_RPC_URL):
# CHAIN_RPC_URLS=https://base-sepolia-rpc.publicnode.com,https://base-sepolia.drpc.org
# CHAIN_CONTRACT=0xD4a724CD7f5C4458cD2d884C2af6f011aC3Af80a
# CHAIN_EXPLORER_URL=https://base-sepolia.blockscout.com
# CHAIN_GAS_LIMIT=500000